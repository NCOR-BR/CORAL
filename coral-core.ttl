###  http://purl.org/ncor-br/c-oral/INT-PAR
coral:INT-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:INT ;
              rdfs:label "INT-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "INT-PAR is a INT tag that has function of denoting a participle form."@en .


