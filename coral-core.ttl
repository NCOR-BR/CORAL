coral:PAR-r rdf:type owl:Class ;
            rdfs:subClassOf coral:PAR ;
            rdfs:label "PAR-r"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "PAR-r is a PAR tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/PRL
coral:PRL rdf:type owl:Class ;
