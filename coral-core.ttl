###  http://purl.org/ncor-br/c-oral/PAR
coral:PAR rdf:type owl:Class ;
          rdfs:subClassOf coral:tag ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:parenthetic
                          ] ;
          rdfs:label "PAR"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "PAR is a tag that has function of marking a parenthetic"@en .


###  http://purl.org/ncor-br/c-oral/PAR-PAR
coral:PAR-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:PAR ;
              rdfs:label "PAR-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "PAR-PAR is a PAR tag that has function of denoting a participle form."@en .


