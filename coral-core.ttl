@prefix : <http://purl.org/ncor-br/c-oral/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix coral: <http://purl.org/ncor-br/c-oral/> .
@base <http://purl.org/ncor-br/c-oral/> .

<http://purl.org/ncor-br/c-oral/> rdf:type owl:Ontology ;
                                   owl:versionIRI <http://purl.org/ncor-br/2024/1/c-oral/> ;
                                   owl:imports <http://purl.obolibrary.org/obo/bfo/2020/bfo.owl> ;
                                   <http://purl.org/dc/elements/1.1/contributor> "Heliana Mello - heliana.mello@gmail.com"@en ,
                                                                                 "Mauricio Almeida - mba@eci.ufmg.br"@en ,
                                                                                 "Tommaso Raso - tommaso.raso@gmail.com"@en ;
                                   <http://purl.org/dc/terms/description> "The C-ORAL-BRASIL project is dedicated to the study of Brazilian Portuguese spontaneous speech and, more broadly, to the compilation of spoken corpora. The LEEL (Laboratory of Empirical and Experimental Studies on Language) lab at the Institute of Languages and Literature at the Federal University of Minas Gerais State (UFMG) represents C-ORAL-BRASIL’s headquarters. The C-ORAL-BRASIL research team is affiliated to the NELC (Research Nucleus on Language, Cognition and Culture). The ontology is work of the C-ORAL experts and knowledge enginners of ReCOL research group."@en ;
                                   <http://purl.org/dc/terms/license> "Creative Commons 4.0"@en ;
                                   <http://purl.org/dc/terms/title> "Informal Spoken Brazilian Portuguese Reference Corpus (C-ORAL-BRASIL) Ontology"@en ;
                                   rdfs:label "CORAL Ontology"@en ;
                                   owl:priorVersion "1.0"@en ;
                                   owl:versionInfo "1.0"@en ;
                                   <https://www.dublincore.org/specifications/dublin-core/dcmi-terms/#created> "June 2024"@en .

#################################################################
#    Annotation properties
#################################################################

###  https://www.dublincore.org/specifications/dublin-core/dcmi-terms/#created
<https://www.dublincore.org/specifications/dublin-core/dcmi-terms/#created> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000050
<http://purl.obolibrary.org/obo/BFO_0000050> rdf:type owl:ObjectProperty ;
                                             rdfs:label "partOf"@en .


###  http://purl.obolibrary.org/obo/OBI_0000299
<http://purl.obolibrary.org/obo/OBI_0000299> rdf:type owl:ObjectProperty ;
                                             rdfs:label "hasSpecifiedOutput"@en .


###  http://purl.org/ncor-br/c-oral/concretizes
coral:concretizes rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/contains
coral:contains rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf coral:storedWith ;
               rdfs:label "contains"@en .


###  http://purl.org/ncor-br/c-oral/hasCharacteristic
coral:hasCharacteristic rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/hasMetadata
coral:hasMetadata rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/hasPart
coral:hasPart rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/hasQuality
coral:hasQuality rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/hasSource
coral:hasSource rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/has_role
coral:has_role rdf:type owl:ObjectProperty ;
               rdfs:label "hasRole"@en .


###  http://purl.org/ncor-br/c-oral/includes
coral:includes rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/isAbout
coral:isAbout rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/isComposedBy
coral:isComposedBy rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/isMarkedBy
coral:isMarkedBy rdf:type owl:ObjectProperty ;
                 owl:inverseOf coral:marks ;
                 rdfs:label "isMarkedBy"@en .


###  http://purl.org/ncor-br/c-oral/isRecordedOf
coral:isRecordedOf rdf:type owl:ObjectProperty ;
                   owl:inverseOf coral:records ;
                   rdfs:label "isRecordedOf"@en .


###  http://purl.org/ncor-br/c-oral/marks
coral:marks rdf:type owl:ObjectProperty ;
            rdfs:label "marks"@en .


###  http://purl.org/ncor-br/c-oral/produces
coral:produces rdf:type owl:ObjectProperty .


###  http://purl.org/ncor-br/c-oral/records
coral:records rdf:type owl:ObjectProperty ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "records"@en .


###  http://purl.org/ncor-br/c-oral/storedWith
coral:storedWith rdf:type owl:ObjectProperty ;
                 rdfs:label "storedWith"@en .


###  http://www.ontologyrepository.com/CommonCoreOntologies/agent_in
<http://www.ontologyrepository.com/CommonCoreOntologies/agent_in> rdf:type owl:ObjectProperty ;
                                                                  rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000056> ;
                                                                  rdfs:comment "agent in"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/IAO_0000030
<http://purl.obolibrary.org/obo/IAO_0000030> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000031> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty coral:isAbout ;
                                                               owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                             ] ;
                                             rdfs:label "information content entity"@en ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "A generically dependent continuant that is about some thing."@en .


###  http://purl.obolibrary.org/obo/IAO_0000300
<http://purl.obolibrary.org/obo/IAO_0000300> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> ;
                                             rdfs:label "textual entity"@en ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "A textual entity is a part of a manifestation (FRBR sense), a generically dependent continuant whose concretizations are patterns of glyphs intended to be interpreted as words, formulas, etc."@en .


###  http://purl.obolibrary.org/obo/IAO_0000305
<http://purl.obolibrary.org/obo/IAO_0000305> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000314> ;
                                             rdfs:label "document title"@en .


###  http://purl.obolibrary.org/obo/IAO_0000310
<http://purl.obolibrary.org/obo/IAO_0000310> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> ;
                                             rdfs:label "document"@en ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "A collection of information content entities intended to be understood together as a whole"@en .


###  http://purl.obolibrary.org/obo/IAO_0000314
<http://purl.obolibrary.org/obo/IAO_0000314> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000050> ;
                                                               owl:someValuesFrom <http://purl.obolibrary.org/obo/IAO_0000310>
                                                             ] ;
                                             rdfs:label "document part" ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "An information content entity that is part of a document." .


###  http://purl.obolibrary.org/obo/IAO_0020002
<http://purl.obolibrary.org/obo/IAO_0020002> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> ;
                                             rdfs:label "utterance"@en ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "An utterance is an information content entity that is a complete unit of speech in spoken language."@en .


###  http://purl.obolibrary.org/obo/IAO_0020008
<http://purl.obolibrary.org/obo/IAO_0020008> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                             rdfs:comment "Sound energy bearing the concretization of an utterance and being the output of an uttering process."@en ;
                                             rdfs:label "utterance energy"@en .


###  http://purl.obolibrary.org/obo/IAO_0020011
<http://purl.obolibrary.org/obo/IAO_0020011> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/OBI_0000011> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                               owl:someValuesFrom <http://purl.obolibrary.org/obo/IAO_0020002>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/OBI_0000299> ;
                                                               owl:someValuesFrom <http://purl.obolibrary.org/obo/IAO_0020008>
                                                             ] ;
                                             rdfs:comment "Utterance process is a planned process of making speech sounds which may or may not have an actual language involved."@en ;
                                             rdfs:label "utterance process"@en .


###  http://purl.obolibrary.org/obo/OBI_0000011
<http://purl.obolibrary.org/obo/OBI_0000011> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                             rdfs:label "planned process"@en ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "A process that realizes a plan which is the concretization of a plan specification."@en .


###  http://purl.org/ncor-br/c-oralcorpus
<http://purl.org/ncor-br/c-oralcorpus> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty coral:isAbout ;
                                                         owl:someValuesFrom coral:audio_file
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty coral:isComposedBy ;
                                                         owl:allValuesFrom coral:text
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty coral:isRecordedOf ;
                                                         owl:allValuesFrom coral:speechProcess
                                                       ] ;
                                       rdfs:comment "Set of texts in electronic format, compiled according to specific criteria and considered representative of what is to be studied (tommaso)"@en ,
                                                    "aggregate of texts" ;
                                       rdfs:label "corpus"@en ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "Corpus is an information content entity that consists of a set of texts in electronic format, compiled according to specific criteria and considered representative of what is to be studied."@en .


###  http://purl.org/ncor-br/c-oralhigh_funcionality_schizophrenics_patient
<http://purl.org/ncor-br/c-oralhigh_funcionality_schizophrenics_patient> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <http://purl.org/ncor-br/patient> ,
                                                                                         [ rdf:type owl:Class ;
                                                                                           owl:unionOf ( coral:schizophrenics_speech_without_video
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty coral:produces ;
                                                                                                           owl:someValuesFrom coral:schizophrenics_speech_with_video
                                                                                                         ]
                                                                                                       )
                                                                                         ] ;
                                                                         rdfs:label "high funcionality schizophrenics patient"@en .


###  http://purl.org/ncor-br/c-orallow_funcionality_schizophrenics_patient
<http://purl.org/ncor-br/c-orallow_funcionality_schizophrenics_patient> rdf:type owl:Class ;
                                                                        rdfs:subClassOf <http://purl.org/ncor-br/patient> ,
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty coral:produces ;
                                                                                          owl:someValuesFrom coral:schizophrenics_speech_with_video
                                                                                        ] ;
                                                                        rdfs:label "low funcionality schizophrenics patient"@en .


###  http://purl.org/ncor-br/patient
<http://purl.org/ncor-br/patient> rdf:type owl:Class ;
                                  rdfs:subClassOf coral:participant ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:someValuesFrom coral:patient_speech_process
                                                  ] ;
                                  rdfs:label "patient"@en ;
                                  <http://www.w3.org/2004/02/skos/core#definition> "Patient is a participant that is realized in a patient speech process."@en .


###  http://purl.org/ncor-br/c-oral/ALL
coral:ALL rdf:type owl:Class ;
          rdfs:subClassOf coral:AUX ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:allocutive
                          ] ;
          rdfs:label "ALL" ;
          <http://www.w3.org/2004/02/skos/core#definition> "ALL is a AUX tag that has function of marking an allocutive"@en .


###  http://purl.org/ncor-br/c-oral/ALL-PAR
coral:ALL-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:ALL ;
              rdfs:label "ALL-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "ALL-PAR is a ALL tag that has function of denoting a participle form."@en .


###  http://purl.org/ncor-br/c-oral/ALL-r
coral:ALL-r rdf:type owl:Class ;
            rdfs:subClassOf coral:ALL ;
            rdfs:label "ALL-r"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "ALL-r is a ALL tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/APC
coral:APC rdf:type owl:Class ;
          rdfs:subClassOf coral:tag ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:appendix_of_comment
                          ] ;
          rdfs:label "APC"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "APC is a tag that has function of marking an appendix of comment"@en .


###  http://purl.org/ncor-br/c-oral/APC-PAR
coral:APC-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:APC ;
              rdfs:label "APC-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "APC-PAR is a APC tag that has function of denoting a participle form."@en .


###  http://purl.org/ncor-br/c-oral/APC-r
coral:APC-r rdf:type owl:Class ;
            rdfs:subClassOf coral:APC ;
            rdfs:label "APC-r"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "APC-r is a APC tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/APT
coral:APT rdf:type owl:Class ;
          rdfs:subClassOf coral:tag ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:appendix_of_topic
                          ] ;
          rdfs:label "APT"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "APT is a tag that has function of marking an appendix of topic"@en .


###  http://purl.org/ncor-br/c-oral/APT-PAR
coral:APT-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:APT ;
              rdfs:label "APT-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "APT-PAR is a APT tag that has function of denoting a participle form." .


###  http://purl.org/ncor-br/c-oral/APT-r
coral:APT-r rdf:type owl:Class ;
            rdfs:subClassOf coral:APT ;
            rdfs:label "APT-r"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "APT-r is a APT tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/AUX
coral:AUX rdf:type owl:Class ;
          rdfs:subClassOf coral:tag ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:dialogic_auxiliary
                          ] ;
          rdfs:label "AUX"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "AUX is a tag that has function of marking a dialogic auxiliary"@en .


###  http://purl.org/ncor-br/c-oral/CMM
coral:CMM rdf:type owl:Class ;
          rdfs:subClassOf coral:tag ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:multiple_comment
                          ] ;
          rdfs:label "CMM"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "CMM is a tag that has function of marking a multiple comment"@en .


###  http://purl.org/ncor-br/c-oral/CMM-PAR
coral:CMM-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:CMM ;
              rdfs:label "CMM-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "CMM-PAR is a CMM tag that has function of denoting a participle form."@en .


###  http://purl.org/ncor-br/c-oral/CMM-r
coral:CMM-r rdf:type owl:Class ;
            rdfs:subClassOf coral:CMM ;
            rdfs:label "CMM-r"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "CMM-r is a CMM tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/CNT
coral:CNT rdf:type owl:Class ;
          rdfs:subClassOf coral:AUX ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:conative
                          ] ;
          rdfs:label "CNT"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "CNT is a AUX tag that has function of marking a conative"@en .


###  http://purl.org/ncor-br/c-oral/CNT-PAR
coral:CNT-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:CNT ;
              rdfs:label "CNT-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "CNT-PAR is a CNT tag that has function of denoting a participle form."@en .


###  http://purl.org/ncor-br/c-oral/CNT-r
coral:CNT-r rdf:type owl:Class ;
            rdfs:subClassOf coral:CNT ;
            rdfs:label "CNT-r"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "CNT-r is a CNT tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/COB
coral:COB rdf:type owl:Class ;
          rdfs:subClassOf coral:tag ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:bound_comment
                          ] ;
          rdfs:label "COB"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "COB is a tag that has function of marking a bound comment"@en .


###  http://purl.org/ncor-br/c-oral/COB-PAR
coral:COB-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:COB ;
              rdfs:label "COB-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "COB-PAR is a COB tag that has function of denoting a participle form."@en .


###  http://purl.org/ncor-br/c-oral/COB-r
coral:COB-r rdf:type owl:Class ;
            rdfs:subClassOf coral:COB ;
            rdfs:label "COB-r"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "COB-r is a COB tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/COB_s
coral:COB_s rdf:type owl:Class ;
            rdfs:subClassOf coral:tag ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty coral:marks ;
                              owl:someValuesFrom coral:subordinator_bound_comment
                            ] ;
            rdfs:label "COB_s"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "COB is a tag that has function of marking a subordinator bound comment"@en .


###  http://purl.org/ncor-br/c-oral/COB_s-PAR
coral:COB_s-PAR rdf:type owl:Class ;
                rdfs:subClassOf coral:COB_s ;
                rdfs:label "COB_s-PAR"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "COB_S-PAR is a COB_s tag that has function of denoting a participle form."@en .


###  http://purl.org/ncor-br/c-oral/COB_s-r
coral:COB_s-r rdf:type owl:Class ;
              rdfs:subClassOf coral:COB_s ;
              rdfs:label "COB_s-r"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "COB_s-r is a COB_s tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/COM
coral:COM rdf:type owl:Class ;
          rdfs:subClassOf coral:tag ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:comment
                          ] ;
          rdfs:comment "COM"@en .


###  http://purl.org/ncor-br/c-oral/COM-PAR
coral:COM-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:COM ;
              rdfs:label "COM-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "COM-PAR is a COM tag that has function of denoting a participle form." .


###  http://purl.org/ncor-br/c-oral/COM-r
coral:COM-r rdf:type owl:Class ;
            rdfs:subClassOf coral:COM ;
            rdfs:label "COM-r"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "COM-r is a COM tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/DCT
coral:DCT rdf:type owl:Class ;
          rdfs:subClassOf coral:AUX ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:discourse_connector
                          ] ;
          rdfs:label "DCT"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "DCT is a AUX tag that has function of marking a discourse connector"@en .


###  http://purl.org/ncor-br/c-oral/DCT-PAR
coral:DCT-PAR rdf:type owl:Class ;
              rdfs:subClassOf coral:DCT ;
              rdfs:label "DCT-PAR"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "DCT-PAR is a DCT tag that has function of denoting a participle form."@en .


###  http://purl.org/ncor-br/c-oral/DCT-r
coral:DCT-r rdf:type owl:Class ;
            rdfs:subClassOf coral:DCT ;
            rdfs:label "DCT-r"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "DCT-r is a DCT tag that has function of denoting an additional phonological feature."@en .


###  http://purl.org/ncor-br/c-oral/EMP
coral:EMP rdf:type owl:Class ;
          rdfs:subClassOf coral:tag ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty coral:marks ;
                            owl:someValuesFrom coral:empty
                          ] ;
          rdfs:label "EMP"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "EMP is a tag that has function of marking an empty"@en .


